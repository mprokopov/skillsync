#!/usr/bin/env bash
set -euo pipefail

# Prefer an installed skillsync (uv tool, ~/.local/bin, etc.).
if command -v skillsync >/dev/null 2>&1; then
  exec skillsync "$@"
fi

# Fallback for running from inside the skillsync repository checkout:
# skills/skill-manager/scripts/skillsync -> repo root is ../../..
SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
REPO_ROOT="$(CDPATH= cd -- "$SCRIPT_DIR/../../.." && pwd)"

if [ -f "$REPO_ROOT/src/skillsync/cli.py" ]; then
  PYTHONPATH="$REPO_ROOT/src${PYTHONPATH:+:$PYTHONPATH}" exec python3 -m skillsync "$@"
fi

cat >&2 <<'ERR'
skillsync CLI not found.

Install it with one of:
  uv tool install ~/Personal/AI/tools/skillsync
  uv tool install "git+https://github.com/mprokopov/skillsync.git"

Or run this skill from inside a skillsync repository checkout.
ERR
exit 127
